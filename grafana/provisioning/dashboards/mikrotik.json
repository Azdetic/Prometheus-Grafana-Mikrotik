    {
      "id": 6,
      "title": "Interface Errors (rate/sec)",
      "description": "Rate of packet errors per second. Any sustained non-zero value indicates a physical layer problem (bad cable, interference, failing hardware).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(ifInErrors{ifDescr=\"ether1\"}[5m])",
          "legendFormat": "Inbound Errors",
          "refId": "A",
          "editorMode": "code",
          "range": true
        },
        {
          "expr": "rate(ifOutErrors{ifDescr=\"ether1\"}[5m])",
          "legendFormat": "Outbound Errors",
          "refId": "B",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "decimals": 2,
          "min": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "none" },
            "axisPlacement": "auto",
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#F2495C", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Inbound Errors" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#F2495C" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Outbound Errors" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF6D00" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
