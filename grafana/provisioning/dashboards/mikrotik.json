{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "NOC-style monitoring dashboard for MikroTik CHR — tracks WAN bandwidth, CPU, memory, and uptime for WiFi/ISP business owners.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 10,
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "System Uptime",
      "description": "Time since the last router reboot. A sudden drop to zero means an outage occurred.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sysUpTime / 100",
          "legendFormat": "Uptime",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#F2495C", "value": null },
              { "color": "#FF9830", "value": 86400 },
              { "color": "#73BF69", "value": 604800 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "value",
        "justifyMode": "center",
        "textMode": "auto",
        "wideLayout": true,
        "orientation": "auto"
      }
    },
    {
      "id": 2,
      "title": "CPU Load",
      "description": "Current CPU utilization. Above 80% sustained means the router is struggling and may need an upgrade.",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "hrProcessorLoad",
          "legendFormat": "CPU %",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 50 },
              { "color": "#FF9830", "value": 70 },
              { "color": "#F2495C", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto",
        "sizing": "auto"
      }
    },
    {
      "id": 3,
      "title": "Memory Usage",
      "description": "RAM utilization. MikroTik routers may become unstable above 85% usage. Plan an upgrade before reaching that threshold.",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "hrStorageUsed{hrStorageDescr=~\".*emory.*\"} / hrStorageSize{hrStorageDescr=~\".*emory.*\"} * 100",
          "legendFormat": "Memory %",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 60 },
              { "color": "#FF9830", "value": 75 },
              { "color": "#F2495C", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto",
        "sizing": "auto"
      }
    },
    {
      "id": 4,
      "title": "ether1 Status",
      "description": "WAN interface operational state. Green = UP (traffic flowing). Red = DOWN (check cable or ISP link).",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "ifOperStatus{ifDescr=\"ether1\"}",
          "legendFormat": "Status",
          "refId": "A",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#F2495C", "value": null },
              { "color": "#73BF69", "value": 1 },
              { "color": "#F2495C", "value": 2 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "UP ✓", "color": "#73BF69" },
                "2": { "text": "DOWN ✗", "color": "#F2495C" },
                "3": { "text": "TESTING", "color": "#FADE2A" }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "graphMode": "none",
        "colorMode": "background_solid",
        "justifyMode": "center",
        "textMode": "auto",
        "wideLayout": true,
        "orientation": "auto"
      }
    },
    {
      "id": 11,
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "title": "WAN Bandwidth — ether1 (Mbps)",
      "description": "Real-time download and upload bandwidth on the WAN interface. This is what the ISP charges for. Rate is calculated over a 5-minute window to smooth out spikes.",
      "type": "timeseries",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(ifHCInOctets{ifDescr=\"ether1\"}[5m]) * 8 / 1000000",
          "legendFormat": "⬇ Download (Mbps)",
          "refId": "A",
          "editorMode": "code",
          "range": true
        },
        {
          "expr": "rate(ifHCOutOctets{ifDescr=\"ether1\"}[5m]) * 8 / 1000000",
          "legendFormat": "⬆ Upload (Mbps)",
          "refId": "B",
          "editorMode": "code",
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Mbits",
          "decimals": 2,
          "min": 0,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": false,
            "showPoints": "never",
            "pointSize": 5,
            "stacking": { "mode": "none" },
            "axisPlacement": "auto",
            "axisLabel": "",
            "axisBorderShow": false,
            "scaleDistribution": { "type": "linear" },
            "barAlignment": 0,
            "axisCenteredZero": false,
            "hideFrom": { "tooltip": false, "viz": false, "legend": false },
            "thresholdsStyle": { "mode": "off" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "⬇ Download (Mbps)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#00C7FF" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "⬆ Upload (Mbps)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showValues": "current",
          "calcs": ["lastNotNull", "mean", "max"]
        }
      }
    },
    {
      "id": 12,
      "title": "",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "collapsed": false,
      "panels": []
